  {
    "id": "fn-alertas",
    "type": "function",
    "z": "tab-casa-iot",
    "name": "Preparar alerta para Sheets e e-mail",
    "func": "const API_KEY = 'meteoro';\nconst EMAIL_FROM = 'pietrolnsousa@gmail.com';\nconst EMAIL_TO = 'nozellasoneto@gmail.com';\n\nconst alerta = msg.payload || {};\nconst texto = Array.isArray(alerta.alertas) ? alerta.alertas.join(', ') : JSON.stringify(alerta);\nconst dataHora = alerta.data_hora || new Date().toISOString();\n\nconst sheetMsg = {\n    headers: { 'Content-Type': 'application/json' },\n    payload: {\n        apiKey: API_KEY,\n        tipo: 'alerta',\n        dataHora,\n        alerta: texto,\n        dados: alerta\n    }\n};\n\nconst emailMsg = {\n    to: EMAIL_TO,\n    from: EMAIL_FROM,\n    topic: `Alerta Casa IoT - ${texto}`,\n    payload: `Alerta detectado: ${texto}\n\nData/hora: ${dataHora}\n\nDados:\n${JSON.stringify(alerta, null, 2)}`\n};\n\nmsg.payload = texto;\nreturn [msg, sheetMsg, emailMsg];",
    "outputs": 3,
    "noerr": 0,
    "initialize": "",
    "finalize": "",
    "libs": [],
    "x": 390,
    "y": 710,
    "wires": [
      [
        "ui-alerta"
      ],
      [
        "http-sheets"
      ],
      [
        "email-alerta"
      ]
    ]
  },
