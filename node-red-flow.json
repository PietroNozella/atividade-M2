    "z": "tab-casa-iot",
    "name": "Preparar registro 2h",
    "func": "const API_KEY = 'meteoro';\nconst status = flow.get('ultimoStatus') || {};\n\nmsg.headers = { 'Content-Type': 'application/json' };\nmsg.payload = {\n    apiKey: API_KEY,\n    tipo: 'leitura_2h',\n    dataHora: new Date().toISOString(),\n    dados: status\n};\nreturn msg;",
